{
  "name": "@virentia/router-react",
  "version": "0.4.0",
  "description": "React bindings for Virentia Router",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/virentia-labs/router.git",
    "directory": "packages/react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@virentia/router": "workspace:*"
  },
  "peerDependencies": {
    "@virentia/react": ">=0.2.2",
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@virentia/core": "^0.7.0",
    "@virentia/react": "^0.3.0",
    "happy-dom": "^20.0.10",
    "history": "^5.3.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vitest": "^4.0.18"
  }
}
