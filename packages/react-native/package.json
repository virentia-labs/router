{
  "name": "@virentia/router-react-native",
  "version": "0.3.0",
  "description": "React Native bindings for Virentia Router",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/virentia-labs/router.git",
    "directory": "packages/react-native"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@virentia/router": "workspace:*",
    "@virentia/router-react": "workspace:*"
  },
  "peerDependencies": {
    "@react-navigation/bottom-tabs": ">=6",
    "@react-navigation/native": ">=6",
    "@react-navigation/stack": ">=6",
    "@virentia/react": ">=0.2.2",
    "react": ">=18",
    "react-native": ">=0.70"
  },
  "devDependencies": {
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "@srsholmes/vitest-react-native": "^0.1.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "^19.2.7",
    "@virentia/core": "^0.6.0",
    "@virentia/react": "^0.2.8",
    "history": "^5.3.0",
    "react": "^19.2.1",
    "react-native": "^0.84.1",
    "react-native-gesture-handler": "^2.31.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-test-renderer": "19.2.6",
    "vitest": "^4.0.18"
  }
}
