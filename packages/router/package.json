  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@virentia/router-paths": "workspace:*",
    "query-string": "^9.3.1"
  },
  "devDependencies": {
    "history": "^5.3.0",
    "vitest": "^4.0.18",
    "@virentia/core": "^0.6.0"
  },
  "peerDependencies": {
    "@virentia/core": ">=0.3.0"
  }
}
