{
  "name": "@virentia/router",
  "version": "0.3.0",
  "description": "Virentia-native router",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/virentia-labs/router.git",
    "directory": "packages/router"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
