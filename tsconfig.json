{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@virentia/router": ["packages/router/lib/index.ts"],
      "@virentia/router-paths": ["packages/paths/lib/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "packages/**/*.tsx"]
}
